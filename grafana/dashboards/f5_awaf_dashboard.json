{
  "title": "F5 AWAF - 실시간 WAF 모니터링",
  "uid": "f5-awaf-dashboard",
  "version": 1,
  "timezone": "Asia/Seoul",
  "tags": ["F5", "AWAF", "WAF", "Security"],
  "schemaVersion": 39,
  "panels": [
    {
      "title": "🛡️ 총 탐지 건수 (24시간)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 3, "h": 3},
      "targets": [{
        "expr": "sum(count_over_time({job=~\"f5_asm_syslog.*\"}[24h]))",
        "legendFormat": "전체 탐지"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 500},
              {"color": "red", "value": 1000}
            ]
          }
        }
      }
    },
    {
      "title": "🚫 차단 건수 (24시간)",
      "type": "stat",
      "gridPos": {"x": 3, "y": 0, "w": 3, "h": 3},
      "targets": [{
        "expr": "sum(count_over_time({job=~\"f5_asm_syslog.*\"} |~ \"request_status=blocked\"[24h]))",
        "legendFormat": "차단"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 100},
              {"color": "red", "value": 300}
            ]
          }
        }
      }
    },
    {
      "title": "⚠️ 탐지율 (차단/전체)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 3, "h": 3},
      "targets": [{
        "expr": "sum(count_over_time({job=~\"f5_asm_syslog.*\"} |~ \"request_status=blocked\"[24h])) / sum(count_over_time({job=~\"f5_asm_syslog.*\"}[24h])) * 100",
        "legendFormat": "차단율"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 30},
              {"color": "green", "value": 70}
            ]
          }
        }
      }
    },
    {
      "title": "🌐 활성 공격자 IP",
      "type": "stat",
      "gridPos": {"x": 9, "y": 0, "w": 3, "h": 3},
      "targets": [{
        "expr": "count(count_over_time({job=~\"f5_asm_syslog.*\"}[1h]) by (src_ip))",
        "legendFormat": "고유 IP"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "title": "📊 공격 추세 (시간별)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 3, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(count_over_time({job=~\"f5_asm_syslog.*\"}[5m]))",
          "legendFormat": "전체 탐지"
        },
        {
          "expr": "sum(count_over_time({job=~\"f5_asm_syslog.*\"} |~ \"request_status=blocked\"[5m]))",
          "legendFormat": "차단"
        },
        {
          "expr": "sum(count_over_time({job=~\"f5_asm_syslog.*\"} |~ \"request_status=alarmed\"[5m]))",
          "legendFormat": "탐지만 (Alarm)"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "🔝 Top 10 공격 유형",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 11, "w": 6, "h": 8},
      "targets": [{
        "expr": "topk(10, sum(count_over_time({job=~\"f5_asm_syslog.*\"}[24h])) by (violation))",
        "legendFormat": "{{ violation }}"
      }],
      "options": {
        "orientation": "horizontal",
        "sort": "desc"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {"mode": "none"}
          }
        }
      }
    },
    {
      "title": "🔝 Top 10 공격자 IP",
      "type": "barchart",
      "gridPos": {"x": 6, "y": 11, "w": 6, "h": 8},
      "targets": [{
        "expr": "topk(10, sum(count_over_time({job=~\"f5_asm_syslog.*\"}[24h])) by (src_ip))",
        "legendFormat": "{{ src_ip }}"
      }],
      "options": {
        "orientation": "horizontal",
        "sort": "desc"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {"mode": "none"}
          }
        }
      }
    },
    {
      "title": "📋 최근 탐지 로그",
      "type": "logs",
      "gridPos": {"x": 0, "y": 19, "w": 12, "h": 10},
      "targets": [{
        "expr": "{job=~\"f5_asm_syslog.*\"} |= ``",
        "legendFormat": ""
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"],
    "time_options": ["5m", "15m", "1h", "6h", "24h", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "attack_type",
        "type": "query",
        "query": "label_values({job=~\"f5_asm_syslog.*\"}, violation)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "src_ip",
        "type": "query",
        "query": "label_values({job=~\"f5_asm_syslog.*\"}, src_ip)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  }
}
