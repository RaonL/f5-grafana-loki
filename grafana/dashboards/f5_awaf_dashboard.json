{
  "title": "F5 AWAF - Real-time WAF Monitoring",
  "uid": "f5-awaf-dashboard",
  "version": 4,
  "timezone": "Asia/Seoul",
  "tags": ["F5", "AWAF", "WAF", "Security", "Loki"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"],
    "time_options": ["5m", "15m", "1h", "6h", "24h", "7d", "30d"]
  },
  "panels": [
    {
      "title": "Total F5 Syslog Events (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 3, "h": 3},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"f5-awaf\"}[24h]))",
          "instant": true,
          "range": false,
          "legendFormat": "syslog events"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 500},
              {"color": "red", "value": 1000}
            ]
          }
        }
      }
    },
    {
      "title": "Total WAF Events (24h)",
      "type": "stat",
      "gridPos": {"x": 3, "y": 0, "w": 3, "h": 3},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"f5-awaf\",request_status!=\"\"}[24h]))",
          "instant": true,
          "range": false,
          "legendFormat": "waf events"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 100},
              {"color": "red", "value": 300}
            ]
          }
        }
      }
    },
    {
      "title": "Block Rate (24h)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 3, "h": 3},
      "targets": [
        {
          "expr": "100 * sum(count_over_time({job=\"f5-awaf\",request_status=\"blocked\"}[24h])) / clamp_min(sum(count_over_time({job=\"f5-awaf\"}[24h])), 1)",
          "instant": true,
          "range": false,
          "legendFormat": "block rate"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 30},
              {"color": "red", "value": 70}
            ]
          }
        }
      }
    },
    {
      "title": "Unique Client IPs (1h)",
      "type": "stat",
      "gridPos": {"x": 9, "y": 0, "w": 3, "h": 3},
      "targets": [
        {
          "expr": "count(sum by (ip_client) (count_over_time({job=\"f5-awaf\",ip_client!=\"\"}[1h])))",
          "instant": true,
          "range": false,
          "legendFormat": "client IPs"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        }
      }
    },
    {
      "title": "WAF Event Trend",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 3, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"f5-awaf\",request_status!=\"\"}[5m]))",
          "legendFormat": "waf total"
        },
        {
          "expr": "sum(count_over_time({job=\"f5-awaf\",request_status=\"blocked\"}[5m]))",
          "legendFormat": "blocked"
        },
        {
          "expr": "sum(count_over_time({job=\"f5-awaf\",request_status=~\"alarmed|alerted\"}[5m]))",
          "legendFormat": "alarmed"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Top 10 Violations (24h)",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 11, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (violations) (count_over_time({job=\"f5-awaf\",violations!=\"\",violations!=\"N/A\"}[24h])))",
          "instant": true,
          "range": false,
          "legendFormat": "{{violations}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "sort": "desc"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {"mode": "none"}
          }
        }
      }
    },
    {
      "title": "Top 10 Client IPs (24h)",
      "type": "barchart",
      "gridPos": {"x": 6, "y": 11, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (ip_client) (count_over_time({job=\"f5-awaf\",ip_client!=\"\"}[24h])))",
          "instant": true,
          "range": false,
          "legendFormat": "{{ip_client}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "sort": "desc"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {"mode": "none"}
          }
        }
      }
    },
    {
      "title": "Top 10 Attack Types (24h)",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 19, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (attack_type) (count_over_time({job=\"f5-awaf\",attack_type!=\"\",attack_type!=\"N/A\"}[24h])))",
          "instant": true,
          "range": false,
          "legendFormat": "{{attack_type}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "sort": "desc"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {"mode": "none"}
          }
        }
      }
    },
    {
      "title": "Top 10 Signatures (24h)",
      "type": "barchart",
      "gridPos": {"x": 6, "y": 19, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "topk(10, sum by (sig_names) (count_over_time({job=\"f5-awaf\",sig_names!=\"\",sig_names!=\"N/A\"}[24h])))",
          "instant": true,
          "range": false,
          "legendFormat": "{{sig_names}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "sort": "desc"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {"mode": "none"}
          }
        }
      }
    },
    {
      "title": "Recent F5 Syslog Logs",
      "type": "logs",
      "gridPos": {"x": 0, "y": 27, "w": 12, "h": 10},
      "targets": [
        {
          "expr": "{job=\"f5-awaf\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "request_status",
        "type": "query",
        "query": "label_values({job=\"f5-awaf\"}, request_status)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "ip_client",
        "type": "query",
        "query": "label_values({job=\"f5-awaf\"}, ip_client)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "policy_name",
        "type": "query",
        "query": "label_values({job=\"f5-awaf\"}, policy_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  }
}
